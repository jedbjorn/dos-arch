# Backup snapshots
**/*.bak.*
**/_backups/
db_backups/

# Python
**/__pycache__/
**/*.pyc
**/*.pyo
.venv/

# Editor
**/.DS_Store
**/*.swp
**/.vscode/

# Node
**/node_modules/
**/dist/
**/.svelte-kit/

# Claude Code: per-user permission overrides — never commit
**/.claude/settings.local.json

# Live DB — bootstrap from schema.sql via `make db-init`
shell_core/shell_db.db
# Any stray DB at the tree root (e.g. a mis-pathed bootstrap) — never commit a DB
/shell_db.db
**/*.sqlite
**/*.sqlite3

# SQLite write-ahead artifacts (transient when DB is open)
**/*.db-journal
**/*.db-wal
**/*.db-shm

# Logs / pm2
**/*.log
**/.pm2/

# Dispatcher process lockfile (runtime artifact)
**/.dispatch_live.lock

# Secrets — keys, KEK material, encrypted secret stores (Phase 1 broker store)
**/.env
**/.env.local
**/secrets.json
**/*.key
**/master.key
**/secrets.db

# Per-shell rendered CLAUDE.md (regenerated by run.py every boot — pure derived state)
shells/*/CLAUDE.md

# pytest
.pytest_cache/
