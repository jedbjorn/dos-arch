# shell-infra .env.example
# Copy to .env and fill in. Read host-side by the credential broker, which
# injects these into shell containers' outbound requests. Never mounted into
# a container; never committed (.env is gitignored).

# Anthropic API key — injected on requests routed through the broker's
# /anthropic route. Shells run `claude` against the broker, not the API
# directly, so this key never enters a container.
ANTHROPIC_API_KEY=

# GitHub token — injected on git-over-HTTPS routed through the broker's /gh
# route. Lets shell containers clone/commit/push credential-free. A
# fine-grained PAT scoped to the repos shells should reach is recommended.
GITHUB_TOKEN=
