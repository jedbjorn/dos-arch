# shell-infra .env.example
# Copy to .env and fill in. Read host-side by the credential broker (for
# shell-container outbound requests) and by the dispatcher pm2 process
# (for browser-chat's direct provider SDK calls). Never mounted into a
# container; never committed (.env is gitignored).

# Anthropic API key — used by (1) the broker's /anthropic route, so shells
# run `claude` against the broker without the key entering a container, and
# (2) the dispatcher's AnthropicAdapter for browser-chat turns.
ANTHROPIC_API_KEY=

# OpenAI API key — used by the dispatcher's OpenAIAdapter for browser-chat
# turns routed to gpt-* models. No broker route today; cloud calls go direct.
OPENAI_API_KEY=

# Ollama Cloud API key — used by the dispatcher's OllamaCloudAdapter as a
# bearer token on /api/chat calls to ollama.com. Catalog discovery
# (/api/tags via `make sync-cloud-models`) is anonymous and does NOT need
# this key. Create one at https://ollama.com/settings/keys.
OLLAMA_CLOUD_API_KEY=

# GitHub token — injected on git-over-HTTPS routed through the broker's /gh
# route. Lets shell containers clone/commit/push credential-free. A
# fine-grained PAT scoped to the repos shells should reach is recommended.
GITHUB_TOKEN=

# Allowed browser origins (CSRF backstop). Comma-separated; the public origin
# the browser uses to reach the app (the Cloudflare domain in prod). A proxied
# state-changing request whose Origin/Referer is not listed is rejected (403).
# Read by dosarch-api via loadEnv(). Defaults to the dev origins when unset.
# APP_ALLOWED_ORIGINS=https://dos-arch.designs-os.com
